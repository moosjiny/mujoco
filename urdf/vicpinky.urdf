<?xml version="1.0" ?>
<robot name="pinky">
  <material name="white"> <color rgba="1 1 1 1"/> </material>
  <material name="gray"> <color rgba="0.2 0.2 0.2 1"/> </material>
  <material name="black"> <color rgba="0 0 0 1"/> </material>
  <material name="blue"> <color rgba="0 0 1 1"/> </material>

  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="-0.2 0 0.05"/>
      <geometry> <box size="0.6 0.4 0.14"/> </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.2 0 0.05"/>
      <geometry> <box size="0.6 0.4 0.14"/> </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="50.0"/>
      <inertia ixx="0.75" ixy="0.0" ixz="0.0" iyy="1.58" iyz="0.0" izz="2.17"/>
    </inertial>
  </link>

  <link name="base_footprint"/>
  <joint name="base_link_fixed_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.0325"/>
  </joint>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin rpy="-1.57079 0 0" xyz="0 0.2375 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="left_wheel">
    <visual>
      <geometry> <cylinder length="0.05" radius="0.0825"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder length="0.05" radius="0.0825"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin rpy="1.57079 0 0" xyz="0 -0.2375 0"/>
    <axis xyz="0 0 -1"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <geometry> <cylinder length="0.05" radius="0.0825"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder length="0.05" radius="0.0825"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
</robot>
