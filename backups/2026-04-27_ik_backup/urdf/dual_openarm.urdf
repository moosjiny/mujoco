<?xml version="1.0"?>
<robot name="wowrobo_openarm_bimanual">
  <!-- MuJoCo extension: actuators / damping defaults / gripper coupling.
       ctrlrange / damping / frictionloss values follow Reazon Research openarm-mjcf v1 (Apache-2.0).
       Damiao motor mapping: j1,j2=DM-J8009P, j3,j4=DM-J4340, j5..7=DM-J4310, fingers=DM-J4310. -->
  <mujoco>
    <compiler fusestatic="false" discardvisual="false"/>
    <actuator>
      <motor name="left_joint1_ctrl"  joint="left_joint_1"  ctrlrange="-10 10"/>
      <motor name="left_joint2_ctrl"  joint="left_joint_2"  ctrlrange="-12 12"/>
      <motor name="left_joint3_ctrl"  joint="left_joint_3"  ctrlrange="-10 10"/>
      <motor name="left_joint4_ctrl"  joint="left_joint_4"  ctrlrange="-10 10"/>
      <motor name="left_joint5_ctrl"  joint="left_joint_5"  ctrlrange="-10 10"/>
      <motor name="left_joint6_ctrl"  joint="left_joint_6"  ctrlrange="-10 10"/>
      <motor name="left_joint7_ctrl"  joint="left_joint_7"  ctrlrange="-10 10"/>
      <motor name="left_finger_ctrl"  joint="left_finger_joint1"  ctrlrange="-0.1 0.1"/>
      <motor name="right_joint1_ctrl" joint="right_joint_1" ctrlrange="-10 10"/>
      <motor name="right_joint2_ctrl" joint="right_joint_2" ctrlrange="-12 12"/>
      <motor name="right_joint3_ctrl" joint="right_joint_3" ctrlrange="-10 10"/>
      <motor name="right_joint4_ctrl" joint="right_joint_4" ctrlrange="-10 10"/>
      <motor name="right_joint5_ctrl" joint="right_joint_5" ctrlrange="-10 10"/>
      <motor name="right_joint6_ctrl" joint="right_joint_6" ctrlrange="-10 10"/>
      <motor name="right_joint7_ctrl" joint="right_joint_7" ctrlrange="-10 10"/>
      <motor name="right_finger_ctrl" joint="right_finger_joint1" ctrlrange="-0.1 0.1"/>
    </actuator>
    <tendon>
      <fixed name="left_finger_split">
        <joint joint="left_finger_joint1" coef="0.5"/>
        <joint joint="left_finger_joint2" coef="0.5"/>
      </fixed>
      <fixed name="right_finger_split">
        <joint joint="right_finger_joint1" coef="0.5"/>
        <joint joint="right_finger_joint2" coef="0.5"/>
      </fixed>
    </tendon>
    <equality>
      <joint joint1="left_finger_joint1"  joint2="left_finger_joint2"  solimp="0.95 0.99 0.001" solref="0.005 1"/>
      <joint joint1="right_finger_joint1" joint2="right_finger_joint2" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    </equality>
  </mujoco>

  <!-- Materials -->
  <material name="matte_black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="metallic_silver"><color rgba="0.7 0.7 0.7 1.0"/></material>
  <material name="finger_grey"><color rgba="0.4 0.4 0.4 1.0"/></material>

  <!-- World -->
  <link name="world"/>

  <link name="base_plate">
    <visual><origin xyz="0 0 0.01"/><geometry><box size="0.4 0.4 0.02"/></geometry><material name="matte_black"/></visual>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/><child link="base_plate"/><origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="central_pillar">
    <visual><origin xyz="0 0 0.4"/><geometry><box size="0.08 0.12 0.8"/></geometry><material name="matte_black"/></visual>
    <inertial><mass value="10.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial>
  </link>

  <joint name="base_to_pillar" type="fixed">
    <parent link="base_plate"/><child link="central_pillar"/><origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="shoulder_block">
    <visual><origin xyz="0 0 0"/><geometry><box size="0.15 0.35 0.18"/></geometry><material name="matte_black"/></visual>
    <inertial><mass value="5.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>

  <joint name="pillar_to_shoulder" type="fixed">
    <parent link="central_pillar"/><child link="shoulder_block"/><origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- LEFT ARM (Gap Closed) -->
  <link name="left_base_link">
    <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="shoulder_to_left_arm" type="fixed"><parent link="shoulder_block"/><child link="left_base_link"/><origin xyz="0 0.0175 0.753" rpy="1.5708 0 0"/></joint>

  <link name="left_link1">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link1.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="left_joint_1" type="revolute"><parent link="left_base_link"/><child link="left_link1"/><origin xyz="0 0 0.0625"/><axis xyz="0 0 1"/><limit lower="-3.14" upper="3.14" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="left_link2">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link2.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="left_joint_2" type="revolute"><parent link="left_link1"/><child link="left_link2"/><origin xyz="-0.0301 0 0.06"/><axis xyz="-1 0 0"/><limit lower="-1.57" upper="1.57" effort="12" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="left_link3">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link3.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.4"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="left_joint_3" type="revolute"><parent link="left_link2"/><child link="left_link3"/><origin xyz="0.0301 0 0.06625"/><axis xyz="0 0 1"/><limit lower="-3.14" upper="3.14" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="left_link4">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link4.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.4"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="left_joint_4" type="revolute"><parent link="left_link3"/><child link="left_link4"/><origin xyz="0 0.0315 0.15375"/><axis xyz="0 1 0"/><limit lower="-1.57" upper="1.57" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="left_link5">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link5.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.3"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
  </link>
  <joint name="left_joint_5" type="revolute"><parent link="left_link4"/><child link="left_link5"/><origin xyz="0 -0.0315 0.0955"/><axis xyz="0 0 1"/><limit lower="-3.14" upper="3.14" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="left_link6">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link6.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.2"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
  </link>
  <joint name="left_joint_6" type="revolute"><parent link="left_link5"/><child link="left_link6"/><origin xyz="0.0375 0 0.1205"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="1.57" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="left_link7">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link7.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.1"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/></inertial>
  </link>
  <joint name="left_joint_7" type="revolute"><parent link="left_link6"/><child link="left_link7"/><origin xyz="-0.0375 0 0"/><axis xyz="0 1 0"/><limit lower="-3.14" upper="3.14" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <!-- LEFT GRIPPER (parallel jaw, simplified box visuals; tendon-coupled in <mujoco> block) -->
  <link name="left_finger_1">
    <visual><origin xyz="0 0 0.02"/><geometry><box size="0.01 0.008 0.04"/></geometry><material name="finger_grey"/></visual>
    <inertial><mass value="0.01"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="left_finger_joint1" type="prismatic"><parent link="left_link7"/><child link="left_finger_1"/><origin xyz="0 0.0075 0.0989"/><axis xyz="0 1 0"/><limit lower="0" upper="0.044" effort="0.1" velocity="0.5"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="left_finger_2">
    <visual><origin xyz="0 0 0.02"/><geometry><box size="0.01 0.008 0.04"/></geometry><material name="finger_grey"/></visual>
    <inertial><mass value="0.01"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="left_finger_joint2" type="prismatic"><parent link="left_link7"/><child link="left_finger_2"/><origin xyz="0 -0.0045 0.0989"/><axis xyz="0 -1 0"/><limit lower="0" upper="0.044" effort="0.1" velocity="0.5"/><dynamics damping="0.25" friction="0.02"/></joint>

  <!-- RIGHT ARM (Gap Closed) -->
  <link name="right_base_link">
    <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="shoulder_to_right_arm" type="fixed"><parent link="shoulder_block"/><child link="right_base_link"/><origin xyz="0 -0.0175 0.753" rpy="-1.5708 0 0"/></joint>

  <link name="right_link1">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link1.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="right_joint_1" type="revolute"><parent link="right_base_link"/><child link="right_link1"/><origin xyz="0 0 0.0625"/><axis xyz="0 0 1"/><limit lower="-3.14" upper="3.14" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="right_link2">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link2.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="right_joint_2" type="revolute"><parent link="right_link1"/><child link="right_link2"/><origin xyz="0.0301 0 0.06"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="1.57" effort="12" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="right_link3">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link3.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.4"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="right_joint_3" type="revolute"><parent link="right_link2"/><child link="right_link3"/><origin xyz="-0.0301 0 0.06625"/><axis xyz="0 0 1"/><limit lower="-3.14" upper="3.14" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="right_link4">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link4.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.4"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="right_joint_4" type="revolute"><parent link="right_link3"/><child link="right_link4"/><origin xyz="0 0.0315 0.15375"/><axis xyz="0 1 0"/><limit lower="-1.57" upper="1.57" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="right_link5">
