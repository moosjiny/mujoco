    <inertial><mass value="0.2"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
  </link>
  <joint name="right_joint_6" type="revolute"><parent link="right_link5"/><child link="right_link6"/><origin xyz="0.0375 0 0.1205"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="1.57" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <link name="right_link7">
    <visual><geometry><mesh filename="/home/ghlee/dev_ws/dual_arms/meshes/link7.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.1"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/></inertial>
  </link>
  <joint name="right_joint_7" type="revolute"><parent link="right_link6"/><child link="right_link7"/><origin xyz="-0.0375 0 0"/><axis xyz="0 1 0"/><limit lower="-3.14" upper="3.14" effort="10" velocity="1"/><dynamics damping="0.25" friction="0.02"/></joint>

  <!-- RIGHT GRIPPER (parallel jaw, simplified box visuals; tendon-coupled in <mujoco> block) -->
